# ─── Clerk (auth) ────────────────────────────────────────────────
# Get these from Clerk Dashboard → API Keys.
# For local dev, use the test/development instance, NOT production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk webhook secret — from Dashboard → Webhooks → your endpoint → Signing secret.
# Only needed if you want user.created / user.updated to sync to Supabase locally.
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Supabase (database, storage, realtime) ──────────────────────
# Get these from Supabase Dashboard → Project Settings → API.
# For local dev, either point at the shared dev project or run `supabase start`
# and use http://localhost:54321 with the CLI-printed keys.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Resend (outbound + inbound email) ───────────────────────────
# Get this from Resend Dashboard → API Keys.
RESEND_API_KEY=re_...
# Inbound webhook signing secret — from Resend Dashboard → Webhooks.
# Only needed if you're testing inbound-email reply processing locally.
RESEND_WEBHOOK_SECRET=whsec_...

# ─── App configuration ───────────────────────────────────────────
# Must include scheme + host. Used in email templates for ticket links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# "From" address used for outbound email. Must be on a Resend-verified domain.
EMAIL_FROM="SFMC Help Desk <support@sfmc.com>"
# Subdomain used to build Reply-To: ticket+T-XXXX@<this>
INBOUND_EMAIL_DOMAIN=reply.sfmc.com

# ─── SLA cron (production only) ──────────────────────────────────
# Not needed locally — Vercel Cron calls /api/sla/check with this header.
# CRON_SECRET=some-random-string
